{
   "compilerOptions": {
      "lib": ["ESNext"],
      "target": "ESNext",
      "module": "Preserve",
      "moduleDetection": "force",
      "jsx": "react-jsx",
      "allowJs": false,

      "moduleResolution": "bundler",
      "allowImportingTsExtensions": true,
      "verbatimModuleSyntax": true,
      "noEmit": true,

      "strict": true,
      "skipLibCheck": true,
      "noFallthroughCasesInSwitch": true,
      "noUncheckedIndexedAccess": true,
      "noImplicitOverride": true,

      "noUnusedLocals": false,
      "noUnusedParameters": false,
      "noPropertyAccessFromIndexSignature": false,

      "isolatedModules": true,
      "esModuleInterop": true,
      "resolveJsonModule": true,

      "baseUrl": ".",
      "paths": {
         "@starfield/database": ["libraries/database/index.ts"],
         "@starfield/mailer": ["libraries/mailer/index.ts"],
         "@starfield/redis": ["libraries/redis/index.ts"],
      },
   },
   "include": [
      "src/**/*.ts",
      "src/**/*.tsx",
      "libraries/**/*.ts",
      "libraries/**/*.tsx",
   ],
   "exclude": [
      "**/node_modules",
      "**/node_modules/**",
      ".git",
      ".zed",
      ".next",
      ".nuxt",
      ".output",
      ".turbo",
      "dist",
      "build",
      "coverage",
   ],
}
